{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@common/*": ["./src/common/*"],
      "@main/*": ["./src/main/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/common/**/*.ts",
    "vite/utils.ts",
    "vite/main.config.ts",
    "vite/preload.config.ts",
    "drizzle.config.ts"
  ]
}
