{
  "name": "devteam",
  "version": "0.0.1",
  "description": "The all-in-one productivity platform for developers",
  "main": "dist/main/index.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "tsx scripts/dev.mts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite/main.config.ts",
    "build:preload": "vite build --config vite/preload.config.ts",
    "build:renderer": "vite build --config vite/renderer.config.ts",
    "compile": "npm run build && electron-builder --config electron-builder.yml",
    "typecheck": "tsc --build --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mts,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
